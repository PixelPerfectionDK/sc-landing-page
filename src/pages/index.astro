---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import Process from "../components/Process.astro";
import Testimonials from "../components/Testimonials.astro";
import CtaBand from "../components/CtaBand.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="SmallClaims - Sikring af jeres retsmæssige krav">
  <!-- Fixed scroll-driven background -->
  <div id="scroll-bg" class="fixed inset-0 -z-10">
    <div id="scroll-bg-gradient" class="absolute inset-0 bg-signin-gradient">
    </div>
    <div
      id="scroll-bg-grain"
      class="absolute inset-0 pointer-events-none [filter:url(#grain)]"
    >
    </div>
    <div
      id="scroll-bg-streak"
      class="absolute top-0 inset-x-0 h-[200px] bg-gradient-to-b from-white/5 to-transparent pointer-events-none"
    >
    </div>
  </div>

  <svg class="absolute w-0 h-0 pointer-events-none">
    <filter id="grain">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.65"
        numOctaves="3"
        stitchTiles="stitch"></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
  </svg>

  <section id="hero" class="sm:py-16">
    <Hero />
  </section>

  <Stats />

  <Process />

  <Testimonials />

  <CtaBand />

  <Footer />
</Layout>

<script>
  import { initScrollBg, lerp, smoothstep } from "../scripts/scroll-bg";

  // One entry per section — see CLAUDE.md "Scroll background" for the contract.
  const SECTION_IDS = [
    "hero",
    "stats",
    "process",
    "testimonials",
    "cta-band",
    "footer",
  ];
  const COLOR_STOPS = [
    { r: 43, g: 79, b: 191 }, // hero top:    rich blue
    { r: 248, g: 249, b: 251 }, // hero bottom / stats top: off-white
    { r: 248, g: 249, b: 251 }, // stats bottom / process top: off-white
    { r: 248, g: 249, b: 251 }, // process bottom / testimonials top: off-white
    { r: 248, g: 249, b: 251 }, // testimonials bottom / cta-band top: off-white (start of fade)
    { r: 22, g: 45, b: 107 }, // cta-band bottom / footer top: dark navy
    { r: 22, g: 45, b: 107 }, // footer bottom: dark navy (stays)
  ];

  // Gradient + grain overlay opacity — only show on blue sections (hero, CTA band, footer).
  function getOverlayOpacity(index: number, t: number): number {
    if (index === 0 && t < 0.5) return 1;
    if (index === 0) return lerp(1, 0, smoothstep((t - 0.5) * 2));
    if (index === 4) return smoothstep(t);
    if (index === 5) return 1;
    return 0;
  }

  initScrollBg(SECTION_IDS, COLOR_STOPS, getOverlayOpacity);
</script>
