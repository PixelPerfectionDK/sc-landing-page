---
import type { GetStaticPathsOptions } from "astro";
import { useStoryblokApi } from "@storyblok/astro";
import Layout from "../../../layouts/Layout.astro";
import CtaBand from "../../../components/CtaBand.astro";
import Footer from "../../../components/Footer.astro";

export const prerender = true;

type BlogStory = {
  slug: string;
  full_slug: string;
  content: {
    Name?: string;
    TTR?: string;
    Image?: { filename?: string; alt?: string };
    Card_text?: string;
    Author?: string[];
    component?: string;
  };
  _author?: { Name?: string; Image?: { filename?: string } } | null;
};

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const storyblokApi = useStoryblokApi();
  const { data } = await storyblokApi.get("cdn/stories", {
    starts_with: "blogs/",
    resolve_relations: "Blog.Author",
    version: import.meta.env.DEV ? "draft" : "published",
    per_page: 100,
    sort_by: "first_published_at:desc",
  });

  const stories: BlogStory[] = (data.stories as BlogStory[])
    .filter((s) => s.content?.component === "Blog")
    .map((story) => ({
      ...story,
      _author: (story.content.Author as any)?.[0]?.content ?? null,
    }));

  return paginate(stories, { pageSize: 12 });
}

const { page } = Astro.props as {
  page: {
    data: BlogStory[];
    currentPage: number;
    lastPage: number;
    url: { prev: string | undefined; next: string | undefined };
  };
};

const pageNumbers = Array.from({ length: page.lastPage }, (_, i) => i + 1);

function pageHref(n: number): string {
  return n === 1 ? "/om-os/viden" : `/om-os/viden/${n}`;
}
---

<Layout
  title="Seneste nyheder og viden | SmallClaims"
  description="Læs vores seneste artikler om småsager, betalingspåkrav, fogedret og civilretlige tvister."
>
  <div class="fixed inset-0 -z-10 bg-signin-gradient"></div>
  <div
    class="fixed inset-0 -z-10 pointer-events-none [filter:url(#grain)] opacity-[0.18]"
  >
  </div>

  <svg class="absolute w-0 h-0 pointer-events-none" aria-hidden="true">
    <filter id="grain">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.65"
        numOctaves="3"
        stitchTiles="stitch"></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
  </svg>

  <section class="max-w-6xl mx-auto px-6 pt-32 text-white">
    <div class="max-w-3xl mx-auto text-center">
      <p
        class="font-mono text-sm font-semibold uppercase tracking-[0.2em] text-white/50 mb-4 animate-fade-up [animation-delay:80ms]"
      >
        Vores verden
      </p>
      <h1
        class="text-4xl md:text-5xl font-bold leading-[1.1] tracking-[-0.02em] mb-6 animate-fade-up [animation-delay:160ms]"
      >
        Seneste nyheder og viden
      </h1>
      <p
        class="text-lg text-white/80 leading-relaxed mb-12 animate-fade-up [animation-delay:240ms]"
      >
        Artikler, vejledning og indsigt om småsager, betalingspåkrav, fogedret
        og civilretlige tvister – fra Small Claims' team.
      </p>
    </div>

    {
      page.data.length === 0 && (
        <p class="text-white/60 italic">Ingen artikler endnu.</p>
      )
    }

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12"
    >
      {
        page.data.map((story) => (
          <a
            href={`/blog/${story.slug}`}
            class="reveal group flex flex-col bg-surface-0 border border-border-deafult rounded-2xl overflow-hidden no-underline shadow-[0_8px_32px_rgba(0,0,0,0.06)] hover:shadow-[0_12px_40px_rgba(0,0,0,0.12)] transition-shadow duration-300"
          >
            {story.content.Image?.filename ? (
              <img
                src={story.content.Image.filename}
                alt={story.content.Image.alt ?? story.content.Name ?? ""}
                class="w-full aspect-[3/2] object-cover"
                loading="lazy"
              />
            ) : (
              <div class="w-full aspect-[3/2] bg-surface-2" />
            )}
            <div class="flex flex-col flex-1 p-6">
              <h3 class="text-lg font-bold text-text-primary leading-snug mb-2 line-clamp-2 group-hover:text-brand-blue transition-colors">
                {story.content.Name}
              </h3>
              {story.content.Card_text && (
                <p class="text-sm text-text-secondary leading-relaxed mb-4 line-clamp-3">
                  {story.content.Card_text}
                </p>
              )}
              <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-border-deafult">
                {story._author ? (
                  <div class="flex items-center gap-2 min-w-0">
                    {story._author.Image?.filename && (
                      <img
                        src={story._author.Image.filename}
                        alt={story._author.Name}
                        class="w-7 h-7 rounded-full object-cover flex-shrink-0"
                        width="28"
                        height="28"
                        loading="lazy"
                      />
                    )}
                    <span class="text-sm text-text-secondary truncate">
                      {story._author.Name}
                    </span>
                  </div>
                ) : (
                  <span />
                )}
                {story.content.TTR && (
                  <span class="font-mono text-xs uppercase tracking-[0.18em] text-text-tertiary flex-shrink-0">
                    {story.content.TTR}
                  </span>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>

    {
      page.lastPage > 1 && (
        <nav
          aria-label="Paginering"
          class="flex items-center justify-between gap-3 pt-8 mb-16 border-t border-white/10"
        >
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="font-mono text-sm uppercase tracking-[0.2em] text-white/70 hover:text-white transition-colors no-underline"
            >
              ← Forrige
            </a>
          ) : (
            <span class="font-mono text-sm uppercase tracking-[0.2em] text-white/20">
              ← Forrige
            </span>
          )}

          <div class="flex items-center gap-1">
            {pageNumbers.map((n) =>
              n === page.currentPage ? (
                <span class="font-mono text-sm font-semibold uppercase tracking-[0.2em] text-white px-3 py-1 bg-white/10 rounded">
                  {n}
                </span>
              ) : (
                <a
                  href={pageHref(n)}
                  class="font-mono text-sm uppercase tracking-[0.2em] text-white/50 hover:text-white transition-colors px-3 py-1 no-underline"
                >
                  {n}
                </a>
              ),
            )}
          </div>

          {page.url.next ? (
            <a
              href={page.url.next}
              class="font-mono text-sm uppercase tracking-[0.2em] text-white/70 hover:text-white transition-colors no-underline"
            >
              Næste →
            </a>
          ) : (
            <span class="font-mono text-sm uppercase tracking-[0.2em] text-white/20">
              Næste →
            </span>
          )}
        </nav>
      )
    }
  </section>

  <CtaBand />
  <Footer />
</Layout>
