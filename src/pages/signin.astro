---
import Layout from '../layouts/Layout.astro';
import { SignIn } from '@clerk/astro/components';
---

<Layout title="Sign In" showNav={false}>
  <main class="relative overflow-hidden flex items-center justify-center min-h-screen">
    <svg class="absolute w-0 h-0 pointer-events-none">
      <filter id="grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
        <feColorMatrix type="saturate" values="0"/>
      </filter>
    </svg>

    <div class="absolute inset-0 bg-signin-gradient"></div>
    <div class="absolute inset-0 opacity-20 pointer-events-none [filter:url(#grain)]"></div>
    <div class="absolute top-0 inset-x-0 h-[200px] bg-gradient-to-b from-white/5 to-transparent pointer-events-none"></div>

    <div class="relative z-10">
      <SignIn appearance={{
        variables: {
          colorPrimary: '#4271f0',
          colorBackground: 'rgba(255, 255, 255, 0.92)',
          fontFamily: 'Manrope, sans-serif',
          borderRadius: '0.75rem',
        },
        elements: {
          card: 'backdrop-blur-xl shadow-2xl border border-white/30',
        },
      }} />
    </div>
  </main>
</Layout>
