---
const DEFAULT_CLAIM = 20000;
const COURT_FEE = 750;
const SUCCESS_FEE_RATE = 0.5;
const HOURLY_RATE = 3125;
const HOURS_MIN = 8;
const HOURS_MAX = 22;
const CLAIM_MAX = 100000;
const CLAIM_STEP = 500;

const claim = DEFAULT_CLAIM;
const successFee = Math.round(claim * SUCCESS_FEE_RATE);
const yourTotal = successFee + COURT_FEE;
const youReceive = claim - yourTotal;
const hours = HOURS_MIN + (claim / CLAIM_MAX) * (HOURS_MAX - HOURS_MIN);
const solicitor = Math.round(hours * HOURLY_RATE);
const youSave = solicitor - yourTotal;

const fmtKr = (n: number) => `${Math.round(n).toLocaleString("da-DK")} kr`;
const fmtHours = (n: number) =>
  `${n.toLocaleString("da-DK", { minimumFractionDigits: 1, maximumFractionDigits: 1 })} timer`;

const trackPct = (claim / CLAIM_MAX) * 100;
---

<section id="pricing" class="px-6 py-24 lg:py-32">
  <div class="max-w-[1140px] mx-auto">
    <!-- Section header -->
    <header class="reveal text-center mb-14 lg:mb-16">
      <p
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue mb-4"
      >
        Prismodel
      </p>
      <h2
        class="text-[clamp(2rem,4vw,3rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-text-primary mb-4"
      >
        Få jeres penge tilbage, <br /> ellers betaler i ingenting.
      </h2>
      <p
        class="text-base lg:text-lg text-text-secondary max-w-[560px] mx-auto leading-relaxed"
      >
        50% af det inddrevne beløb. Det er hele regningen — og i betaler kun,
        hvis i får jeres penge tilbage.
      </p>
    </header>

    <div
      class="lg:grid lg:grid-cols-[1fr_1fr] lg:gap-16 lg:items-center max-w-[1040px] mx-auto"
    >
      <!-- Annotation panel (lg+ only) -->
      <aside class="reveal hidden lg:block relative pl-8">
        <div
          class="absolute left-0 top-1 bottom-1 w-px bg-gradient-to-b from-brand-blue/40 via-brand-blue/15 to-transparent"
          aria-hidden="true"
        >
        </div>
        <p
          class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue mb-5"
        >
          Hvordan vi arbejder
        </p>
        <h3
          class="text-[clamp(1.6rem,2.4vw,2.1rem)] font-extrabold leading-[1.15] tracking-[-0.02em] text-text-primary mb-5"
        >
          I betaler kun<br />for resultatet.
        </h3>
        <p class="text-[15px] leading-[1.65] text-text-secondary mb-4">
          Ingen timepris. Ingen forudbetaling. Vi bruger kun ressourcer på sager
          vi tror på — og bærer hele risikoen for udfaldet.
        </p>
        <p class="text-[15px] leading-[1.65] text-text-secondary">
          Vinder vi, deler vi det inddrevne beløb 50/50. Taber vi, betaler du
          intet. <span class="text-text-primary font-semibold"
            >Det er hele modellen.</span
          >
        </p>
      </aside>

      <!-- Calculator card -->
      <div class="reveal max-w-[440px] w-full mx-auto lg:mx-0">
        <div
          class="bg-white rounded-2xl px-6 py-7 sm:px-8 sm:py-8 [box-shadow:0_18px_30px_rgba(15,30,80,0.10),_0_3px_6px_rgba(0,0,0,0.04)]"
        >
          <!-- Slider section -->
          <p
            class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue mb-3"
          >
            Sagens beløb
          </p>
          <div
            id="calc-amount"
            class="font-extrabold text-[clamp(2rem,4vw,2.75rem)] tracking-[-0.03em] text-brand-blue leading-none mb-5"
          >
            {fmtKr(claim)}
          </div>

          <input
            id="calc-slider"
            type="range"
            min="2000"
            max={CLAIM_MAX}
            step={CLAIM_STEP}
            value={claim}
            aria-label="Sagens beløb"
            aria-valuetext={`${claim.toLocaleString("da-DK")} kroner`}
            class="calc-slider w-full"
            style={`--track-pct: ${trackPct}%`}
          />
          <div class="flex justify-between mt-2 mb-7">
            <span class="font-mono text-[10px] text-text-tertiary"
              >2.000 kr</span
            >
            <span class="font-mono text-[10px] text-text-tertiary"
              >100.000 kr</span
            >
          </div>

          <!-- Line items -->
          <div
            class="border-t border-dashed border-black/[0.10] pt-4 flex flex-col gap-3"
          >
            <div class="flex justify-between items-baseline">
              <span
                class="text-[15px] text-text-secondary flex items-center gap-1.5"
              >
                Retsgebyr
                <span class="calc-info-wrap relative inline-flex">
                  <button
                    type="button"
                    class="calc-info inline-flex items-center justify-center w-4 h-4 rounded-full border border-text-tertiary/40 text-text-tertiary text-[9px] font-bold leading-none hover:border-brand-blue/60 hover:text-brand-blue focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue/50"
                    aria-label="Info om retsgebyr"
                    aria-describedby="calc-court-tooltip"
                  >
                    i
                  </button>
                  <span
                    id="calc-court-tooltip"
                    role="tooltip"
                    class="calc-tooltip"
                  >
                    Fastsat af retsvæsenet. Betales kun hvis kravet skal føres i
                    retten.
                  </span>
                </span>
              </span>
              <span class="text-text-primary font-semibold text-[15px]"
                >750 kr</span
              >
            </div>
            <div class="flex justify-between items-baseline">
              <span class="text-[15px] text-text-secondary">
                Vores honorar <span class="text-text-tertiary">(50%)</span>
              </span>
              <span
                id="calc-success"
                class="text-text-primary font-semibold text-[15px]"
              >
                {fmtKr(successFee)}
              </span>
            </div>
          </div>

          <div class="my-4 border-t-[2.5px] border-black/15"></div>

          <!-- You receive -->
          <div class="flex justify-between items-baseline mb-6">
            <span
              class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-text-tertiary"
            >
              Du modtager
            </span>
            <span
              id="calc-receive"
              class="font-extrabold text-[clamp(1.6rem,3vw,2.25rem)] tracking-[-0.04em] text-brand-blue leading-none"
            >
              {fmtKr(youReceive)}
            </span>
          </div>

          <!-- Savings band -->
          <div class="rounded-xl bg-brand-blue/8 px-4 py-3.5 mb-5">
            <p class="text-[15px] leading-snug text-text-primary">
              Du sparer
              <span id="calc-save" class="font-extrabold text-lg"
                >{fmtKr(youSave)}</span
              >
              sammenlignet med en traditionel advokat.
            </p>
            <p class="text-[12px] text-text-tertiary mt-1">
              ~<span id="calc-hours">{fmtHours(hours)}</span> á 3.125 kr/h
            </p>
          </div>

          <!-- CTA -->
          <a
            href="/signup"
            class="calc-cta block w-full text-center bg-brand-blue text-white font-semibold py-3.5 rounded-xl transition duration-150 hover:brightness-95 hover:-translate-y-px"
          >
            Start din sag
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animate, type AnimationPlaybackControls } from "motion";

  const CLAIM_MAX = 100000;
  const COURT_FEE = 750;
  const SUCCESS_FEE_RATE = 0.5;
  const HOURLY_RATE = 3125;
  const HOURS_MIN = 8;
  const HOURS_MAX = 22;

  const fmtKr = (n: number) => `${Math.round(n).toLocaleString("da-DK")} kr`;
  const fmtHours = (n: number) =>
    `${n.toLocaleString("da-DK", { minimumFractionDigits: 1, maximumFractionDigits: 1 })} timer`;

  const slider = document.getElementById(
    "calc-slider",
  ) as HTMLInputElement | null;
  const elAmount = document.getElementById("calc-amount");
  const elSuccess = document.getElementById("calc-success");
  const elReceive = document.getElementById("calc-receive");
  const elSave = document.getElementById("calc-save");
  const elHours = document.getElementById("calc-hours");

  if (slider && elAmount && elSuccess && elReceive && elSave && elHours) {
    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const easing = [0.16, 1, 0.3, 1] as const;
    const TWEEN_MS = 250;

    type Tween = {
      el: HTMLElement;
      current: number;
      controls: AnimationPlaybackControls | null;
      format: (n: number) => string;
    };

    const make = (
      el: HTMLElement,
      initial: number,
      format: (n: number) => string,
    ): Tween => ({
      el,
      current: initial,
      controls: null,
      format,
    });

    const initialClaim = Number(slider.value);
    const initial = {
      claim: initialClaim,
      successFee: initialClaim * SUCCESS_FEE_RATE,
      youReceive: initialClaim - initialClaim * SUCCESS_FEE_RATE - COURT_FEE,
      hours: HOURS_MIN + (initialClaim / CLAIM_MAX) * (HOURS_MAX - HOURS_MIN),
      youSave:
        (HOURS_MIN + (initialClaim / CLAIM_MAX) * (HOURS_MAX - HOURS_MIN)) *
          HOURLY_RATE -
        (initialClaim * SUCCESS_FEE_RATE + COURT_FEE),
    };

    const tweens = {
      amount: make(elAmount, initial.claim, fmtKr),
      success: make(elSuccess, initial.successFee, fmtKr),
      receive: make(elReceive, initial.youReceive, fmtKr),
      save: make(elSave, initial.youSave, fmtKr),
      hours: make(elHours, initial.hours, fmtHours),
    };

    const tween = (t: Tween, target: number) => {
      if (reduced) {
        t.current = target;
        t.el.textContent = t.format(target);
        return;
      }
      t.controls?.stop();
      const from = t.current;
      t.controls = animate(from, target, {
        duration: TWEEN_MS / 1000,
        ease: easing,
        onUpdate: (v) => {
          t.current = v;
          t.el.textContent = t.format(v);
        },
      });
    };

    const compute = (claim: number) => {
      const successFee = claim * SUCCESS_FEE_RATE;
      const yourTotal = successFee + COURT_FEE;
      const youReceive = claim - yourTotal;
      const hours = HOURS_MIN + (claim / CLAIM_MAX) * (HOURS_MAX - HOURS_MIN);
      const solicitor = hours * HOURLY_RATE;
      const youSave = solicitor - yourTotal;
      return { claim, successFee, youReceive, hours, youSave };
    };

    const render = (claim: number) => {
      const v = compute(claim);
      tween(tweens.amount, v.claim);
      tween(tweens.success, v.successFee);
      tween(tweens.receive, v.youReceive);
      tween(tweens.save, v.youSave);
      tween(tweens.hours, v.hours);
      const pct = (v.claim / CLAIM_MAX) * 100;
      slider.style.setProperty("--track-pct", `${pct}%`);
      slider.setAttribute(
        "aria-valuetext",
        `${Math.round(v.claim).toLocaleString("da-DK")} kroner`,
      );
    };

    slider.addEventListener("input", () => {
      const claim = Number(slider.value);
      render(claim);
    });
  }

  const infoBtn = document.querySelector<HTMLButtonElement>(".calc-info");
  const infoWrap = document.querySelector<HTMLElement>(".calc-info-wrap");

  if (infoBtn && infoWrap) {
    infoBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      if (infoWrap.hasAttribute("data-open")) {
        infoWrap.removeAttribute("data-open");
      } else {
        infoWrap.setAttribute("data-open", "");
      }
    });

    document.addEventListener("click", (e) => {
      if (!infoWrap.contains(e.target as Node)) {
        infoWrap.removeAttribute("data-open");
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") infoWrap.removeAttribute("data-open");
    });
  }
</script>

<style>
  /* ---- Slider ---- */
  .calc-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      var(--color-brand-blue) 0%,
      var(--color-brand-blue) var(--track-pct, 20%),
      rgba(15, 30, 80, 0.1) var(--track-pct, 20%),
      rgba(15, 30, 80, 0.1) 100%
    );
    cursor: pointer;
    outline: none;
  }

  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: white;
    border: 2px solid var(--color-brand-blue);
    box-shadow: 0 2px 6px rgba(15, 30, 80, 0.18);
    cursor: grab;
    transition:
      transform 150ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 150ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .calc-slider::-moz-range-thumb {
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: white;
    border: 2px solid var(--color-brand-blue);
    box-shadow: 0 2px 6px rgba(15, 30, 80, 0.18);
    cursor: grab;
    transition:
      transform 150ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 150ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .calc-slider:hover::-webkit-slider-thumb {
    box-shadow:
      0 2px 6px rgba(15, 30, 80, 0.18),
      0 0 0 6px rgba(66, 113, 240, 0.15);
  }
  .calc-slider:hover::-moz-range-thumb {
    box-shadow:
      0 2px 6px rgba(15, 30, 80, 0.18),
      0 0 0 6px rgba(66, 113, 240, 0.15);
  }

  .calc-slider:active::-webkit-slider-thumb {
    transform: scale(1.15);
    cursor: grabbing;
  }
  .calc-slider:active::-moz-range-thumb {
    transform: scale(1.15);
    cursor: grabbing;
  }

  .calc-slider:focus-visible::-webkit-slider-thumb {
    box-shadow:
      0 2px 6px rgba(15, 30, 80, 0.18),
      0 0 0 4px rgba(66, 113, 240, 0.45);
  }
  .calc-slider:focus-visible::-moz-range-thumb {
    box-shadow:
      0 2px 6px rgba(15, 30, 80, 0.18),
      0 0 0 4px rgba(66, 113, 240, 0.45);
  }

  /* ---- Tooltip (court fee) ---- */
  .calc-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    width: max-content;
    max-width: 240px;
    padding: 8px 10px;
    border-radius: 8px;
    background: rgb(22, 45, 107);
    color: white;
    font-size: 12px;
    line-height: 1.4;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 160ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 160ms cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 10;
  }
  .calc-tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: rgb(22, 45, 107);
  }

  .calc-info-wrap:hover .calc-tooltip,
  .calc-info-wrap:focus-within .calc-tooltip,
  .calc-info-wrap[data-open] .calc-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .calc-tooltip {
      transition: none;
    }
  }
</style>
