---
const colTitle =
  "text-[11px] font-bold uppercase tracking-[1.5px] text-white/30 mb-4";
const linkCls =
  "block text-[13.5px] text-white/50 hover:text-white/85 no-underline transition-colors duration-200 py-1";
const plainCls = "block text-[13.5px] text-white/50 py-1";
---

<footer id="footer" class="text-white/50">
  <div
    class="max-w-[1060px] mx-auto px-6 pt-16 pb-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr] gap-10"
  >
    <div>
      <div
        class="text-base font-bold text-white mb-3 tracking-[-0.3px]"
      >
        smallclaims.ai
      </div>
      <p class="text-[13px] leading-[1.6] max-w-[260px]">
        Software-faciliteret inddrivelse af retskrav. Vi gør det nemt at vinde
        din sag.
      </p>
    </div>

    <div>
      <div class={colTitle}>Navigation</div>
      <a class={linkCls} href="#process">Sådan virker det</a>
      <a class={linkCls} href="#pricing">Pris</a>
      <a class={linkCls} href="#testimonials">Kunderne</a>
      <a class={linkCls} href="#">FAQ</a>
      <a class={linkCls} href="#">Om os</a>
    </div>

    <div>
      <div class={colTitle}>Kontakt</div>
      <a class={linkCls} href="mailto:info@smallclaims.ai"
        >info@smallclaims.ai</a
      >
      <a class={linkCls} href="tel:+4527132622">+45 27 13 26 22</a>
      <span class={plainCls}>Tirs/Tors kl. 10–12</span>
    </div>

    <div>
      <div class={colTitle}>Adresse</div>
      <span class={plainCls}>Sortedam Dossering 55</span>
      <span class={plainCls}>2100 København Ø</span>
      <span class={plainCls}>CVR: 43188739</span>
    </div>
  </div>

  <div
    class="max-w-[1060px] mx-auto px-6 pb-8 pt-6 border-t border-white/[0.06] flex flex-col gap-3 text-center md:flex-row md:justify-between md:items-center md:text-left"
  >
    <span class="text-[12px] text-white/50"
      >© 2026 SmallClaims ApS. Alle rettigheder forbeholdes.</span
    >
    <div class="flex justify-center md:justify-end gap-5">
      <a
        class="text-[12px] text-white/35 hover:text-white/60 no-underline transition-colors duration-200"
        href="#">Privatlivspolitik</a
      >
      <a
        class="text-[12px] text-white/35 hover:text-white/60 no-underline transition-colors duration-200"
        href="#">Vilkår</a
      >
      <a
        class="text-[12px] text-white/35 hover:text-white/60 no-underline transition-colors duration-200"
        href="#">Cookiepolitik</a
      >
    </div>
  </div>
</footer>
