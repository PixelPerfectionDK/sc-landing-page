<section id="process" class="px-6 py-8 lg:py-16">
  <div class="max-w-[1140px] mx-auto">
    <header class="reveal text-center mb-14">
      <p
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue mb-4"
      >
        Sådan virker det
      </p>
      <h2
        class="text-[clamp(2rem,4vw,3rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-text-primary mb-4"
      >
        Du bruger 5 minutter.<br />Vi klarer resten.
      </h2>
      <p
        class="text-base lg:text-lg text-text-secondary max-w-[520px] mx-auto leading-relaxed"
      >
        Tre trin: du uploader, vi tager over, og du får dine penge.
      </p>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      <!-- Card 1: Upload -->
      <article
        class="reveal relative overflow-hidden rounded-2xl p-7 bg-gradient-to-br from-brand-blue/[0.06] to-brand-blue/[0.02] border border-brand-blue/10 shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        style="transition-delay: 50ms"
      >
        <span
          class="inline-block font-mono text-[10px] font-semibold uppercase tracking-[2px] mb-3.5 text-brand-blue"
          >Du · Trin 1</span
        >
        <div
          class="w-10 h-10 rounded-[10px] flex items-center justify-center mb-4 bg-brand-blue/10"
        >
          <svg
            class="w-5 h-5 text-brand-blue"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10 3v8M7 8l3 3 3-3"></path>
            <path d="M3 13v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"></path>
          </svg>
        </div>
        <h3
          class="text-base font-bold text-text-primary tracking-[-0.3px] mb-1.5"
        >
          Upload din sag
        </h3>
        <p class="text-[13.5px] leading-[1.55] text-text-secondary">
          Faktura, kontrakt, kontaktoplysninger. Det tager omkring 5 minutter.
        </p>
        <div class="mt-3.5 flex flex-col gap-1.5">
          <div
            class="flex items-center gap-2 px-2.5 py-2 bg-surface-1 rounded-lg border border-dashed border-brand-blue/20"
          >
            <svg
              class="w-3.5 h-3.5 text-brand-blue shrink-0"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M8 1H3.5A1.5 1.5 0 0 0 2 2.5v9A1.5 1.5 0 0 0 3.5 13h7a1.5 1.5 0 0 0 1.5-1.5V5L8 1z"
              ></path>
              <path d="M8 1v4h4"></path>
            </svg>
            <span class="text-[11px] font-medium text-text-secondary flex-1"
              >faktura-0472.pdf</span
            >
            <span class="font-mono text-[11px] font-bold text-accent-green"
              >✓</span
            >
          </div>
          <div
            class="flex items-center justify-between px-2.5 py-1.5 bg-surface-1 rounded-lg"
          >
            <span class="text-[10.5px] font-medium text-text-tertiary"
              >Beløb</span
            >
            <span class="font-mono text-[11px] font-semibold text-text-primary"
              >DKK 47.500</span
            >
          </div>
          <div
            class="flex items-center justify-between px-2.5 py-1.5 bg-surface-1 rounded-lg"
          >
            <span class="text-[10.5px] font-medium text-text-tertiary"
              >Debitor</span
            >
            <span class="font-mono text-[11px] font-semibold text-text-primary"
              >Firma ApS</span
            >
          </div>
        </div>
      </article>

      <!-- Card 2: We take over -->
      <article
        class="reveal relative overflow-hidden rounded-2xl p-7 bg-surface-0 shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        style="transition-delay: 120ms"
      >
        <span
          class="inline-block font-mono text-[10px] font-semibold uppercase tracking-[2px] mb-3.5 text-text-tertiary"
          >Vi · Trin 2</span
        >
        <div
          class="w-10 h-10 rounded-[10px] flex items-center justify-center mb-4 bg-surface-1"
        >
          <svg
            class="w-5 h-5 text-brand-blue"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10 2L3 5v5c0 4 3 7 7 8 4-1 7-4 7-8V5l-7-3z"></path>
            <path d="M7.5 10l1.8 1.8L13 8"></path>
          </svg>
        </div>
        <h3
          class="text-base font-bold text-text-primary tracking-[-0.3px] mb-1.5"
        >
          Vi tager over
        </h3>
        <p class="text-[13.5px] leading-[1.55] text-text-secondary">
          Vi vurderer sagen, forhandler med modparten, og fører den i retten
          hvis det bliver nødvendigt.
        </p>
        <div class="mt-3.5 flex flex-col gap-1.5">
          {
            [
              "Vurdering & strategi",
              "Forhandling med modpart",
              "Retssag og dom",
              "Inddrivelse via fogedretten",
            ].map((item) => (
              <div class="flex items-center gap-2 px-2.5 py-1.5 bg-surface-1 rounded-lg text-[12.5px] font-medium text-text-secondary">
                <svg
                  class="w-3 h-3 text-brand-blue shrink-0"
                  viewBox="0 0 12 12"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2.5 6.2l2.4 2.3 4.6-5" />
                </svg>
                {item}
              </div>
            ))
          }
        </div>
      </article>

      <!-- Card 3: Get paid -->
      <article
        class="reveal relative overflow-hidden rounded-2xl p-7 bg-gradient-to-br from-brand-blue/[0.06] to-brand-blue/[0.02] border border-brand-blue/10 shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        style="transition-delay: 190ms"
      >
        <span
          class="inline-block font-mono text-[10px] font-semibold uppercase tracking-[2px] mb-3.5 text-brand-blue"
          >Du · Trin 3</span
        >
        <div
          class="w-10 h-10 rounded-[10px] flex items-center justify-center mb-4 bg-brand-blue/10"
        >
          <svg
            class="w-5 h-5 text-brand-blue"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2.5" y="6" width="15" height="10" rx="1.5"></rect>
            <path d="M2.5 9h15"></path>
            <circle cx="14" cy="13" r="1"></circle>
          </svg>
        </div>
        <h3
          class="text-base font-bold text-text-primary tracking-[-0.3px] mb-1.5"
        >
          Få dine penge
        </h3>
        <p class="text-[13.5px] leading-[1.55] text-text-secondary">
          Når sagen er afgjort, ender pengene på din konto. Du betaler kun, hvis
          vi har vundet for dig.
        </p>
        <div class="mt-3.5 flex flex-col gap-1.5">
          <div
            class="flex items-center justify-between px-2.5 py-2 bg-surface-1 rounded-lg"
          >
            <span
              class="text-[10.5px] font-medium uppercase tracking-[0.05em] text-text-tertiary"
              >Status</span
            >
            <span class="font-mono text-[11px] font-semibold text-text-primary"
              >Vundet</span
            >
          </div>
          <div
            class="flex items-center gap-2 px-2.5 py-2.5 bg-accent-green-light/10 border border-dashed border-accent-green-light/30 rounded-lg"
          >
            <svg
              class="w-3.5 h-3.5 text-accent-green shrink-0"
              viewBox="0 0 14 14"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M2.5 7.2l2.4 2.3L11.5 3"></path>
            </svg>
            <span class="text-[11px] font-medium text-text-secondary flex-1"
              >Inddrevet</span
            >
            <span class="font-mono text-[12px] font-bold text-accent-green"
              >DKK 47.500</span
            >
          </div>
        </div>
      </article>
    </div>

    <div
      class="reveal mt-7 flex items-center justify-center gap-1.5 text-[13px] font-medium text-text-tertiary"
      style="transition-delay: 300ms"
    >
      <svg
        class="w-4 h-4"
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
      >
        <path d="M2.5 8.5l3.5 3.5 7.5-8"></path>
      </svg>
      Gennemsnitligt 14 dages sagsbehandling
    </div>
  </div>
</section>
