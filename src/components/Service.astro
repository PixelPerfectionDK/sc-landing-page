---
import { Image } from "astro:assets";

const { image, title, description } = Astro.props;
---

<div
  class="flex flex-col gap-4 items-center text-center bg-white/10 border border-white/10 rounded-2xl p-6 md:grid md:grid-rows-subgrid md:row-span-3 md:justify-items-center md:items-start"
>
  <Image src={image} alt={title} />
  <h3 class="text-2xl font-bold text-white">{title}</h3>
  <p class="text-md text-white/85">{description}</p>
</div>
