---
import { Image } from "astro:assets";

interface Props {
  name: string;
  title: string;
  image: ImageMetadata;
}

const { name, title, image } = Astro.props;
---

<div
  class="flex flex-col items-center justify-center gap-2 bg-white/20 border border-white/10 rounded-2xl p-6"
>
  <Image
    src={image}
    alt={name}
    width={100}
    height={100}
    class="rounded-full border-2 border-white"
  />
  <h3 class="text-xl font-bold text-text-primary text-center">{name}</h3>
  <p class="text-md text-text-secondary italic text-center">{title}</p>
</div>
