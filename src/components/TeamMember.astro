---
import { Image } from "astro:assets";

interface Props {
  name: string;
  title: string;
  description: string;
  image: ImageMetadata;
}

const { name, title, description, image } = Astro.props;
---

<div
  class="flex flex-col items-center justify-center gap-2 bg-white/20 border border-white/10 rounded-2xl p-3 max-w-[200px] mx-auto w-full"
>
  <Image
    src={image}
    alt={name}
    width={100}
    height={100}
    class="rounded-full border-2 border-white/20 object-cover shadow-lg"
  />
  <h3 class="text-base font-semibold text-white text-center">{name}</h3>
  <p class="text-sm text-white/80 text-center">{title}</p>
  <p class="text-xs text-white/60 text-center italic">{description}</p>
</div>
