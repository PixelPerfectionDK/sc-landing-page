---
---

<nav
  id="nav"
  class="group fixed inset-x-0 top-0 z-[100] px-6 py-4 transition-[padding] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] data-[scrolled]:py-[10px]"
>
  <div class="
    max-w-[1100px] mx-auto flex items-center px-6 py-3 rounded-full border border-transparent
    transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]
    group-data-[scrolled]:max-w-[680px]
    group-data-[scrolled]:bg-white/82
    group-data-[scrolled]:backdrop-blur-[20px]
    group-data-[scrolled]:backdrop-saturate-[180%]
    group-data-[scrolled]:border-white/30
    group-data-[scrolled]:shadow-[0_4px_24px_rgba(0,0,0,0.06),0_1px_2px_rgba(0,0,0,0.04)]
  ">

    <a
      href="/"
      class="
        flex items-center gap-2 text-white text-[15px] font-extrabold tracking-[-0.5px] no-underline
        transition-colors duration-500
        [&_polygon]:fill-white [&_polygon]:transition-colors [&_polygon]:duration-500
        group-data-[scrolled]:text-text-primary
        group-data-[scrolled]:[&_polygon]:fill-brand-blue
      "
    >
      <svg class="w-5 h-6 shrink-0" viewBox="0 0 58.4 67.67" xmlns="http://www.w3.org/2000/svg">
        <polygon points="58.4 16.92 58.4 35.11 56.05 33.75 53.13 32.06 50.79 30.71 47.65 28.88 34.77 21.42 29.97 18.64 24.41 21.87 19.15 24.91 13.89 21.87 19.15 18.82 24.71 15.6 29.97 12.55 35.23 15.6 40.03 18.38 47.65 22.79 53.13 25.97 53.13 13.86 58.4 16.92" opacity="0.85"/>
        <polygon points="47.65 10.69 47.65 16.78 45.22 15.37 40.42 12.59 35.16 9.54 29.2 6.09 24.01 9.1 18.75 12.14 13.19 15.37 10.54 16.9 7.93 18.41 5.27 19.96 5.27 22.82 8.76 24.84 10.54 25.87 14.02 27.89 18.82 30.67 34.84 39.95 29.58 42.99 29.58 42.99 13.56 33.71 10.54 31.96 8.76 30.93 8.76 30.93 5.27 28.91 3.5 27.89 0 25.86 0 16.92 2.68 15.37 5.27 13.87 7.93 12.32 10.54 10.81 13.5 9.1 18.75 6.05 23.95 3.05 29.2 0 34.46 3.05 40.42 6.5 45.67 9.54 47.65 10.69"/>
        <polygon points="58.4 41.56 58.4 50.69 53.13 53.74 47.65 56.92 44.8 58.57 39.54 61.62 34.35 64.63 34.34 64.63 29.09 67.67 23.83 64.63 18.55 61.57 10.54 56.93 10.54 50.84 13.3 52.43 18.55 55.48 18.56 55.48 23.81 58.52 29.09 61.58 34.28 58.57 39.54 55.52 45.37 52.14 47.65 50.83 53.13 47.65 53.13 44.6 50.49 43.07 47.65 41.42 45.23 40.02 39.97 36.98 23.95 27.69 29.21 24.65 45.23 33.93 47.65 35.33 50.49 36.98 53.13 38.51 55.74 40.02 58.4 41.56" opacity="0.85"/>
        <polygon points="45.35 46.04 40.1 49.09 40.1 49.09 34.27 52.47 29.01 55.51 18.49 49.42 10.54 44.81 5.27 41.76 5.27 53.87 0 50.82 0 32.61 2.93 34.31 5.27 35.67 7.73 37.09 10.54 38.72 23.75 46.37 29.01 49.42 29.01 49.42 34.84 46.04 40.1 43 45.35 46.04"/>
      </svg>
      smallclaims
    </a>

    <ul class="flex gap-1 mx-auto list-none p-0 m-0">
      {[
        { href: '#process', label: 'Sådan virker det' },
        { href: '#pricing', label: 'Pris' },
        { href: '#proof',   label: 'Om os' },
        { href: '#faq',     label: 'FAQ' },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="
              text-white/75 text-[13.5px] font-medium px-[14px] py-[6px] rounded-full no-underline
              transition-all duration-300
              hover:text-white hover:bg-white/10
              group-data-[scrolled]:text-text-secondary
              group-data-[scrolled]:hover:text-text-primary
              group-data-[scrolled]:hover:bg-surface-1
            "
          >{label}</a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="#"
        class="
          px-5 py-2 rounded-full text-white text-[13px] font-semibold no-underline
          bg-white/15 border border-white/20 backdrop-blur-sm
          transition-all duration-300
          hover:bg-white/25 hover:border-white/[0.35]
          group-data-[scrolled]:bg-brand-blue
          group-data-[scrolled]:border-brand-blue
          group-data-[scrolled]:[backdrop-filter:none]
          group-data-[scrolled]:shadow-[0_2px_8px_rgba(66,113,240,0.3)]
          group-data-[scrolled]:hover:bg-brand-blue-dark
          group-data-[scrolled]:hover:border-brand-blue-dark
        "
      >
        Opret din sag
      </a>
    </div>

  </div>
</nav>

<script>
  const nav = document.getElementById('nav') as HTMLElement;

  function onScroll() {
    nav.toggleAttribute('data-scrolled', window.scrollY > 60);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
