---
const numberCls =
  "font-mono text-[clamp(2.5rem,4vw,3.5rem)] font-bold leading-none text-brand-blue tracking-[-2px] mb-2";
const labelCls = "text-sm font-medium text-text-secondary";
---

<section id="stats" class="px-6 py-4 lg:py-8">
  <div class="max-w-[1140px] mx-auto">
    <div data-stats class="reveal grid grid-cols-2 lg:grid-cols-4">
      <div class="stat-divider text-center py-10 px-6">
        <div class={numberCls} data-target="96" data-suffix="%">0%</div>
        <div class={labelCls}>Sager vundet</div>
      </div>
      <div class="stat-divider text-center py-10 px-6">
        <div
          class={numberCls}
          data-target="500"
          data-suffix="+"
          data-duration="1800"
        >
          0
        </div>
        <div class={labelCls}>Vundne sager</div>
      </div>
      <div class="stat-divider text-center py-10 px-6">
        <div class={numberCls}>0 kr</div>
        <div class={labelCls}>Forudbetaling</div>
      </div>
      <div class="stat-divider text-center py-10 px-6">
        <div class={numberCls}>&lt; 5 min</div>
        <div class={labelCls}>At komme i gang</div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animate, inView } from "motion";

  const containers = document.querySelectorAll<HTMLElement>("[data-stats]");

  containers.forEach((container) => {
    const numbers = container.querySelectorAll<HTMLElement>("[data-target]");

    inView(
      container,
      () => {
        const animations = Array.from(numbers).map((el) => {
          const target = Number(el.dataset.target);
          const suffix = el.dataset.suffix ?? "";
          const durationMs = Number(el.dataset.duration ?? 1400);

          return animate(0, target, {
            duration: durationMs / 1000,
            ease: "circOut",
            onUpdate: (latest) => {
              el.textContent = Math.round(latest) + suffix;
            },
          });
        });

        return () => {
          animations.forEach((a) => a.stop());
          numbers.forEach((el) => {
            el.textContent = "0" + (el.dataset.suffix ?? "");
          });
        };
      },
      { amount: 0.3 },
    );
  });
</script>
