---
import { animate, scroll } from "motion";
import TeamMember from "./TeamMember.astro";

import placeholder from "../assets/team/placeholder.jpeg";

interface TeamMember {
  name: string;
  title: string;
  description: string;
  image: ImageMetadata;
}

const team: TeamMember[] = [
  {
    name: "Christian Olson",
    title: "Founder & CEO",
    description: "Ledelse og strategi",
    image: placeholder,
  },
  {
    name: "Anton Claudius",
    title: "COO",
    description: "Ledelse og strategi",
    image: placeholder,
  },
  {
    name: "Paul Kvisgaard",
    title: "CTO",
    description: "Udvikling og teknologi",
    image: placeholder,
  },
  {
    name: "Matteo Giorgio",
    title: "Jurist",
    description: "Juridisk rådgivning",
    image: placeholder,
  },
  {
    name: "Oliver Bach",
    title: "Jurist",
    description: "Juridisk rådgivning",
    image: placeholder,
  },
  {
    name: "Gustav Rasmussen",
    title: "Jurist",
    description: "Juridisk rådgivning",
    image: placeholder,
  },
  {
    name: "Martin Pedersen",
    title: "Fullstack Udvikler",
    description: "Udvikling og teknologi",
    image: placeholder,
  },
  {
    name: "Mikkel Jørgensen",
    title: "UX Designer",
    description: "Design og brugeroplevelse",
    image: placeholder,
  },
];
---

<section id="team" class="py-16 lg:py-24">
  <div class="max-w-[1140px] mx-auto bg-brand-blue px-6 py-12 sm:rounded-2xl">
    <header class="reveal text-center mb-12 lg:mb-14">
      <p
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-white/80 mb-4"
      >
        Mød SmallClaims
      </p>
      <h2
        class="text-[clamp(2rem,4vw,3rem)] text-center mx-auto max-w-[560px] font-extrabold leading-[1.2] tracking-[-0.03em] text-white mb-4"
      >
        Vores team står klar til at hjælpe dig.
      </h2>
    </header>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {team.map((member) => <TeamMember {...member} />)}
    </div>
  </div>
</section>

<script>
  import { animate, inView } from "motion";

  const team = document.querySelectorAll("#team .reveal");

  team.forEach((member) => {
    inView(member, (element) => {
      animate(element, { opacity: 1, y: 0 }, { duration: 0.5 });
    });
  });
</script>
