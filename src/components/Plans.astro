<section id="plans" class="px-6 py-16 lg:py-24">
  <div class="max-w-[1140px] mx-auto">
    <header class="reveal text-center mb-14 lg:mb-16">
      <p
        class="font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-brand-blue mb-4"
      >
        Vores planer
      </p>
      <h2
        class="text-[clamp(2rem,4vw,3rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-text-primary mb-4"
      >
        Vælg den plan, der passer til jer.
      </h2>
      <p
        class="text-base lg:text-lg text-text-secondary max-w-[560px] mx-auto leading-relaxed"
      >
        Uanset om I har én sag i klemme eller indrivelse er en fast del af jeres
        forretning — der er en plan, der passer.
      </p>
    </header>

    <div
      class="grid grid-cols-1 lg:grid-cols-3 gap-5 lg:grid-rows-[auto_auto_auto_1fr_auto]"
    >
      <!-- Standard -->
      <article
        class="reveal relative flex flex-col lg:grid lg:grid-rows-subgrid lg:row-span-5 overflow-hidden rounded-2xl p-7 bg-surface-0 border border-border-deafult shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        data-reveal-delay="50"
      >
        <div class="mb-5 lg:mb-0">
          <h3
            class="text-[clamp(1.5rem,2.2vw,1.9rem)] font-extrabold leading-[1.15] tracking-[-0.02em] text-text-primary mb-2"
          >
            Standard
          </h3>
          <p class="text-[14px] leading-[1.6] text-text-secondary">
            For jer med en sag i klemme her og nu. Hurtig opstart, ingen binding —
            vi tager risikoen.
          </p>
        </div>

        <div class="mb-5 lg:mb-0">
          <p
            class="text-[clamp(1.3rem,1.9vw,1.6rem)] font-extrabold tracking-[-0.02em] text-text-primary leading-tight"
          >
            50% af inddrevet beløb
          </p>
          <p class="text-[13px] text-text-tertiary mt-1">
            + 100% af gebyrer, renter og sagsomkostninger
          </p>
        </div>

        <div class="h-px bg-border-deafult mb-5 lg:mb-0"></div>

        <ul class="flex-1 flex flex-col gap-2.5 mb-6 lg:mb-0">
          {
            [
              "No cure no pay",
              "Opstart med det samme",
              "Ingen binding",
              "Ingen opstartsgebyr",
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[14px] text-text-secondary">
                <svg
                  class="w-3.5 h-3.5 mt-1 text-brand-blue shrink-0"
                  viewBox="0 0 14 14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2.5 7.2l2.4 2.3L11.5 3" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>

        <a
          href="/signin"
          class="inline-flex items-center justify-center w-full px-5 py-3 rounded-xl bg-brand-blue text-white text-[14px] font-semibold tracking-[-0.01em] hover:bg-brand-blue-dark transition-colors"
        >
          Opret sag
        </a>
      </article>

      <!-- Business (highlighted with corner ribbon) -->
      <article
        class="reveal relative flex flex-col lg:grid lg:grid-rows-subgrid lg:row-span-5 overflow-hidden rounded-2xl p-7 bg-surface-0 border border-border-deafult shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        data-reveal-delay="120"
      >
        <div
          class="absolute top-[26px] -right-[46px] w-[180px] py-1.5 rotate-45 bg-brand-blue text-bg-page text-center font-mono text-[10px] font-bold uppercase tracking-[2px] pointer-events-none shadow-[0_2px_8px_rgba(43,89,201,0.25)] z-10"
          aria-hidden="true"
        >
          Populær
        </div>

        <div class="mb-5 lg:mb-0">
          <h3
            class="text-[clamp(1.5rem,2.2vw,1.9rem)] font-extrabold leading-[1.15] tracking-[-0.02em] text-text-primary mb-2"
          >
            Business
          </h3>
          <p class="text-[14px] leading-[1.6] text-text-secondary">
            For virksomheder med løbende sager. I kører alle jeres småsager
            gennem os — så belønner vi volumen med lavere satser.
          </p>
        </div>

        <div class="mb-5 lg:mb-0">
          <p
            class="text-[clamp(1.3rem,1.9vw,1.6rem)] font-extrabold tracking-[-0.02em] text-text-primary leading-tight"
          >
            Trappesats — fra 50% og ned
          </p>
          <p class="text-[13px] text-text-tertiary mt-1">
            Jo højere krav, jo lavere provision
          </p>
        </div>

        <div class="h-px bg-border-deafult mb-5 lg:mb-0"></div>

        <ul class="flex-1 flex flex-col gap-2.5 mb-6 lg:mb-0">
          {
            [
              "No cure no pay",
              "Rammeaftale med trappesats",
              "Prioriteret sagsbehandling",
              "Fast kontaktperson",
            ].map((item) => (
              <li class="flex items-start gap-2.5 text-[14px] text-text-secondary">
                <svg
                  class="w-3.5 h-3.5 mt-1 text-brand-blue shrink-0"
                  viewBox="0 0 14 14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2.5 7.2l2.4 2.3L11.5 3" />
                </svg>
                {item}
              </li>
            ))
          }
        </ul>

        <a
          href="#kontakt"
          class="inline-flex items-center justify-center w-full px-5 py-3 rounded-xl bg-text-primary text-white text-[14px] font-semibold tracking-[-0.01em] hover:bg-text-secondary transition-colors"
        >
          Book møde
        </a>
      </article>

      <!-- Enterprise -->
      <article
        class="reveal relative flex flex-col lg:grid lg:grid-rows-subgrid lg:row-span-5 overflow-hidden rounded-2xl p-7 bg-surface-0 border border-border-deafult shadow-[0_8px_32px_rgba(0,0,0,0.06)]"
        data-reveal-delay="190"
      >
        <div class="mb-5 lg:mb-0">
          <h3
            class="text-[clamp(1.5rem,2.2vw,1.9rem)] font-extrabold leading-[1.15] tracking-[-0.02em] text-text-primary mb-2"
          >
            Enterprise
          </h3>
          <p class="text-[14px] leading-[1.6] text-text-secondary">
            For større virksomheder med høje volumener og faste flows. Fast
            månedligt abonnement plus lav provision — tilpasset jeres antal sager
            og kontraktværdier.
          </p>
        </div>

        <div class="mb-5 lg:mb-0">
          <p
            class="text-[clamp(1.3rem,1.9vw,1.6rem)] font-extrabold tracking-[-0.02em] text-text-primary leading-tight"
          >
            Fast abonnement + lav provision
          </p>
          <p class="text-[13px] text-text-tertiary mt-1">
            Skræddersyet til jeres volumen
          </p>
        </div>

        <div class="h-px bg-border-deafult mb-5 lg:mb-0"></div>

        <div class="flex-1 flex flex-col mb-6 lg:mb-0">
          <ul class="flex flex-col gap-2.5 mb-5">
            {
              [
                "Maksimalt afkast af inddrivelsen",
                "Dedikeret sagsbehandler",
                "API-integration til jeres ERP",
                "SLA og rapportering",
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-[14px] text-text-secondary">
                  <svg
                    class="w-3.5 h-3.5 mt-1 text-brand-blue shrink-0"
                    viewBox="0 0 14 14"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M2.5 7.2l2.4 2.3L11.5 3" />
                  </svg>
                  {item}
                </li>
              ))
            }
          </ul>
          <p
            class="text-[12.5px] leading-[1.55] text-text-tertiary lg:mt-auto"
          >
            Abonnementet modregnes i de inddrevne beløb — først når det er
            dækket, opkræver vi den lave provision af det overskydende.
          </p>
        </div>

        <a
          href="#kontakt"
          class="inline-flex items-center justify-center w-full px-5 py-3 rounded-xl bg-text-primary text-white text-[14px] font-semibold tracking-[-0.01em] hover:bg-text-secondary transition-colors"
        >
          Book møde
        </a>
      </article>
    </div>
  </div>
</section>
